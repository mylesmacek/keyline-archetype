# Copy to .env.local for local development (never commit .env.local).
# On Vercel: Project → Settings → Environment Variables, or `vercel env pull .env.local`

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: Vercel AI Gateway (unified routing; prefer OIDC on Vercel — see docs/INTEGRATIONS.md)
# AI_GATEWAY_API_KEY=
